# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=events
KAFKA_GROUP_ID=write-service-group

# S3 / MinIO
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=events-bucket
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Service
HTTP_PORT=8085
NUM_CONSUMERS=3

# Buffer
BUFFER_LIMIT=10000
BUFFER_SIZE_LIMIT=20971520
FLUSH_INTERVAL=10s

# WAL
WAL_WRITE_INTERVAL=500ms

# Dedup
ENABLE_DEDUPLICATION=true
DEDUPLICATION_WINDOW=5m